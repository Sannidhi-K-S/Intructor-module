generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Session {
  id            Int    @id @default(autoincrement())
  session_title String

  instructor_id Int
  student_id    String

  aircraft_id  Int?
  simulator_id Int?

  training_type TrainingType?

  lesson_plan_id Int?

  start_time DateTime
  end_time   DateTime
  notes      String?

  created_at DateTime @default(now())

  lessonPlan         LessonPlan?          @relation(fields: [lesson_plan_id], references: [id])
}

enum TrainingType {
  Flight_Training
  Simulator
  Ground_School
}

model LessonPlan {
  id              Int     @id @default(autoincrement())
  topic           String
  instructorNotes String?
  expectedOutcome String?

  created_at DateTime @default(now())

  // RELATIONS
  sessions   Session[]
  objectives LessonObjective[]
  exercises  Exercise[]
}

model LessonObjective {
  id             Int    @id @default(autoincrement())
  lesson_plan_id Int
  text           String

  lessonPlan LessonPlan @relation(fields: [lesson_plan_id], references: [id])
}

model Exercise {
  id             Int     @id @default(autoincrement())
  lesson_plan_id Int
  name           String
  type           String?

  lessonPlan LessonPlan @relation(fields: [lesson_plan_id], references: [id])
}

model Trainee {
  id             String    @id @default(uuid())
  traineeId      String
  name           String
  email          String
  phone          String?
  dob            DateTime?
  enrollmentDate DateTime
  course         String?
  licenseType    String?
  status         String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Instructor {
  id           Int     @id @default(autoincrement())
  instructorId String  @unique @default("INST-001")
  name         String
  email        String  @unique
  phone        String?
  designation  String // e.g., "Senior Flight Instructor"

  status String? // active/inactive (optional)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model TrainingData {
  id Int @id @default(autoincrement())

  session_id Int

  mode  String?
  topic String?

  instructor_id Int
  resource_id   String?
  traineeId     String

  debrief_summary    String?
  additional_remarks String?
  session_outcome    String?

  created_at DateTime @default(now())

  exercises SessionExercise[]
}

model SessionExercise {
  id Int @id @default(autoincrement())

  training_id Int

  exercise_name String
  exercise_type String

  score     Float
  completed Boolean @default(false)

  notes String?

  created_at DateTime @default(now())

  training TrainingData @relation(fields: [training_id], references: [id])
}
