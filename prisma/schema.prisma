generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model exercise {
  id             Int        @id @default(autoincrement())
  lesson_plan_id Int
  name           String
  type           String?
  lessonplan     lessonplan @relation(fields: [lesson_plan_id], references: [id], map: "Exercise_lesson_plan_id_fkey")

  @@index([lesson_plan_id], map: "Exercise_lesson_plan_id_fkey")
}

model instructor {
  id           Int      @id @default(autoincrement())
  instructorId String   @unique(map: "Instructor_instructorId_key") @default("INST-001")
  name         String
  email        String   @unique(map: "Instructor_email_key")
  phone        String?
  designation  String
  status       String?  @default("active")
  created_at   DateTime @default(now())
  updated_at   DateTime
}

model lessonobjective {
  id             Int        @id @default(autoincrement())
  lesson_plan_id Int
  text           String
  lessonplan     lessonplan @relation(fields: [lesson_plan_id], references: [id], map: "LessonObjective_lesson_plan_id_fkey")

  @@index([lesson_plan_id], map: "LessonObjective_lesson_plan_id_fkey")
}

model lessonplan {
  id              Int               @id @default(autoincrement())
  topic           String
  instructorNotes String?           @db.Text
  expectedOutcome String?           @db.Text
  created_at      DateTime          @default(now())
  exercise        exercise[]
  lessonobjective lessonobjective[]
  session         session[]
}

model session {
  id             Int                    @id @default(autoincrement())
  session_title  String
  instructor_id  Int
  student_id     String
  aircraft_id    Int?
  simulator_id   Int?
  training_type  session_training_type?
  lesson_plan_id Int?
  start_time     DateTime
  end_time       DateTime
  notes          String?
  created_at     DateTime               @default(now())
  lessonplan     lessonplan?            @relation(fields: [lesson_plan_id], references: [id], map: "Session_lesson_plan_id_fkey")

  @@index([lesson_plan_id], map: "Session_lesson_plan_id_fkey")
}

model sessionexercise {
  id            Int          @id @default(autoincrement())
  training_id   Int
  exercise_id   Int?
  exercise_name String
  exercise_type String
  score         Float
  canvas_data   String?      @db.LongText
  completed     Boolean      @default(false)
  notes         String?      @db.Text
  created_at    DateTime     @default(now())
  trainingdata  trainingdata @relation(fields: [training_id], references: [id], map: "SessionExercise_training_id_fkey")

  @@index([training_id], map: "SessionExercise_training_id_fkey")
}

model trainee {
  id             String    @id
  traineeId      String
  name           String
  email          String
  phone          String?
  dob            DateTime?
  enrollmentDate DateTime
  course         String?
  licenseType    String?
  status         String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime
}

model trainingdata {
  id                 Int               @id @default(autoincrement())
  session_id         Int               @unique(map: "TrainingData_session_id_key")
  mode               String?
  topic              String?
  instructor_id      Int
  resource_id        String?
  traineeId          String
  debrief_summary    String?           @db.Text
  additional_remarks String?           @db.Text
  session_outcome    String?
  created_at         DateTime          @default(now())
  sessionexercise    sessionexercise[]
}

enum session_training_type {
  Flight_Training
  Simulator
  Ground_School
}
